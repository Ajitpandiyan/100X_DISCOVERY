version: '3.8'

services:
  backend:
    build: ./backend
    ports:
      - "${PORT}:8000"
    volumes:
      - ./backend:/app
    env_file:
      - .env.production
    command: uvicorn app.main:app --host 0.0.0.0 --port 8000

  frontend:
    build: ./frontend
    ports:
      - "8501:8501"
    volumes:
      - ./frontend:/app
    env_file:
      - .env.production
    depends_on:
      - backend
    command: streamlit run src/app.py

